# Copia para .env.local e preenche.
# Em prod (Vercel), configura essas mesmas variaveis em Settings > Environment Variables.

# URL da API Alpha OS (Render).
API_BASE_URL=https://alpha-os.onrender.com

# Token Bearer que o backend espera (DASHBOARD_API_TOKEN no Render).
# Use o mesmo valor nos dois lados.
API_TOKEN=trocar-pra-um-segredo-forte-aqui

# Senha de acesso ao painel da agencia (auth basica).
# Em prod, gera uma forte e troca aqui + no Vercel.
DASHBOARD_PASSWORD=trocar
