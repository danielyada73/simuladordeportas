# Variáveis de Ambiente — Simulador de Ambientes
# Copie este arquivo para .env e preencha os valores

# ============================================
# WHATSAPP CLOUD API (Meta)
# ============================================
ALPHA_OS_MODE=true
WHATSAPP_TOKEN=seu_token_permanente_aqui
WHATSAPP_PHONE_NUMBER_ID=1115376094990099
PHONE_NUMBER_ID=1115376094990099
WABA_ID=952620424037700
WHATSAPP_VERIFY_TOKEN=simulador2026
WEBHOOK_VERIFY_TOKEN=simulador2026

# ============================================
# REPLICATE API
# ============================================
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# GOOGLE SHEETS
# ============================================
GOOGLE_SHEETS_SPREADSHEET_ID=id_da_sua_planilha_aqui
GOOGLE_CREDENTIALS_JSON={...service_account_json...}

# ============================================
# CLOUDFLARE R2 (Storage de imagens)
# ============================================
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY_ID=seu_access_key
R2_SECRET_ACCESS_KEY=seu_secret_key
R2_BUCKET_NAME=simulador-imagens
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ============================================
# GATEWAY DE PAGAMENTO (escolha um)
# ============================================
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
# ou
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ============================================
# ALPHA OS - Monday
# ============================================
MONDAY_API_TOKEN=seu_token_monday_aqui
MONDAY_API_URL=https://api.monday.com/v2
ALPHA_OS_ONBOARDING_PRAZO=15 Dias
ALPHA_OS_ONBOARDING_SEGMENTO=via WhatsApp

# ============================================
# ALPHA OS - n8n
# ============================================
N8N_ONBOARDING_WEBHOOK_URL=https://seu-n8n.com/form/seu_form_id
N8N_PHASE2_WEBHOOK_URL=https://seu-n8n.com/webhook/status_monday
N8N_GOOGLE_PUBLISH_WEBHOOK_URL=https://seu-n8n.com/webhook/aprovacao_campads
N8N_META_PUBLISH_WEBHOOK_URL=https://seu-n8n.com/webhook/publicar_meta
N8N_DAILY_ANALYSIS_WEBHOOK_URL=https://seu-n8n.com/webhook/analise_diaria
N8N_WEEKLY_ANALYSIS_WEBHOOK_URL=https://seu-n8n.com/webhook/analise_semanal
